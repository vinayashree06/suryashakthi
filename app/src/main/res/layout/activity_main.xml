<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#F5F5F5">

        <!-- App Title -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SuryaShakthi Solar Monitor"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="20dp"/>

        <!-- Energy Generated -->

        <EditText
            android:id="@+id/etGenerated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Energy Generated (kWh)"
            android:inputType="numberDecimal"
            android:padding="12dp"
            android:textSize="16sp"
            android:backgroundTint="#4CAF50"/>

        <!-- Energy Consumed -->

        <EditText
            android:id="@+id/etConsumed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Energy Consumed (kWh)"
            android:inputType="numberDecimal"
            android:padding="12dp"
            android:textSize="16sp"
            android:backgroundTint="#4CAF50"
            android:layout_marginTop="12dp"/>

        <!-- Weather Spinner -->

        <Spinner
            android:id="@+id/spinnerWeather"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"/>

        <!-- Calculate Button -->

        <Button
            android:id="@+id/btnCalculate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CALCULATE"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:layout_marginTop="20dp"/>

        <!-- History Button -->

        <Button
            android:id="@+id/btnHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VIEW HISTORY"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#388E3C"
            android:layout_marginTop="12dp"/>

        <!-- Analytics Button -->

        <Button
            android:id="@+id/btnAnalytics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VIEW ANALYTICS"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1B5E20"
            android:layout_marginTop="12dp"/>

        <!-- Export PDF Button -->

        <Button
            android:id="@+id/btnExport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EXPORT PDF REPORT"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#D32F2F"
            android:layout_marginTop="12dp"/>

        <!-- Result Card -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Result -->

                <TextView
                    android:id="@+id/tvResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Result will appear here"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#212121"/>

                <!-- Progress Bar -->

                <ProgressBar
                    android:id="@+id/progressEfficiency"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#4CAF50"
                    android:layout_marginTop="18dp"/>

                <!-- Efficiency -->

                <TextView
                    android:id="@+id/tvEfficiency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Efficiency: 0%"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginTop="14dp"/>

                <!-- Status -->

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status will appear here"
                    android:textSize="16sp"
                    android:textColor="#4CAF50"
                    android:layout_marginTop="10dp"/>

                <!-- AI Suggestions -->

                <TextView
                    android:id="@+id/tvSuggestion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Suggestions will appear here"
                    android:textSize="15sp"
                    android:textColor="#1565C0"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>